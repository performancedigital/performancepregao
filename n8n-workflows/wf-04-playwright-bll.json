            "index": 0
          }
        ]
      ]
    },
    "Scrape BLL via Playwright Worker": {
      "main": [
        [
          {
            "node": "Check Scrape Success",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Check Scrape Success": {
      "main": [
        [
          {
            "node": "Normalize BLL Data",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Scrape Failed",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Normalize BLL Data": {
      "main": [
        [
          {
            "node": "Upsert BLL Biddings to Postgres",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
